{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "ext-iconv": "*",
        "ext-json": "*",
        "api-platform/core": "^3.2",
        "doctrine/doctrine-bundle": "^2.7",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/orm": "^2.18",
        "easycorp/easyadmin-bundle": "^4.0",
        "egulias/email-validator": "^3.1",
        "friendsofsymfony/ckeditor-bundle": "^2.0",
        "helios-ag/fm-elfinder-bundle": "^12.5",
        "hidehalo/nanoid-php": "^1.1",
        "incenteev/composer-parameter-handler": "^2.1",
        "lexik/jwt-authentication-bundle": "*",
        "liip/imagine-bundle": "^2.0",
        "nelmio/cors-bundle": "^2.4",
        "phpdocumentor/reflection-docblock": "^5.3",
        "sentry/sentry-symfony": "^4.3",
        "stof/doctrine-extensions-bundle": "^1.3",
        "stripe/stripe-php": "^14.7",
        "symfony/apache-pack": "^1.0",
        "symfony/asset": "6.4.*",
        "symfony/brevo-mailer": "6.4.*",
        "symfony/console": "6.4.*",
        "symfony/dotenv": "^5.4 || ^6.0",
        "symfony/expression-language": "6.4.*",
        "symfony/flex": "^2.1",
        "symfony/form": "6.4.*",
        "symfony/framework-bundle": "6.4.*",
        "symfony/http-client": "6.4.*",
        "symfony/http-kernel": "6.4.*",
        "symfony/mailer": "6.4.*",
        "symfony/messenger": "6.4.*",
        "symfony/monolog-bundle": "^3.1",
        "symfony/notifier": "6.4.*",
        "symfony/process": "6.4.*",
        "symfony/property-access": "6.4.*",
        "symfony/property-info": "6.4.*",
        "symfony/proxy-manager-bridge": "6.4.*",
        "symfony/runtime": "6.4.*",
        "symfony/security-bundle": "6.4.*",
        "symfony/sendinblue-mailer": "6.4.*",
        "symfony/serializer": "6.4.*",
        "symfony/string": "6.4.*",
        "symfony/templating": "6.4.*",
        "symfony/uid": "6.4.*",
        "symfony/ux-twig-component": "^2.9",
        "symfony/validator": "6.4.*",
        "symfony/web-link": "6.4.*",
        "symfony/webpack-encore-bundle": "^2.1",
        "symfony/yaml": "6.4.*",
        "twig/cssinliner-extra": "^3.8",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/twig": "^2.12|^3.0",
        "vich/uploader-bundle": "^2.9"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^6.0",
        "deployer/deployer": "^7.0",
        "doctrine/doctrine-fixtures-bundle": "^3.0",
        "fakerphp/faker": "^1.23",
        "friendsofphp/php-cs-fixer": "^3.3",
        "jetbrains/phpstorm-attributes": "^1.0",
        "maxwellmc/doctrine-fixtures-autonumber-reset-bundle": "^2.0",
        "pestphp/pest": "^2.6",
        "phpspec/phpspec": "^7.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^1.8.4",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpstan/phpstan-doctrine": "^1.3.2",
        "phpstan/phpstan-webmozart-assert": "^1.1",
        "rector/rector": "*",
        "roave/security-advisories": "dev-latest",
        "symfony/browser-kit": "^6.4",
        "symfony/css-selector": "6.4.*",
        "symfony/debug-bundle": "^6.4",
        "symfony/intl": "^6.4",
        "symfony/web-profiler-bundle": "^6.4",
        "symplify/config-transformer": "*",
        "tomasvotruba/symfony-config-generator": "^0.1.7"
    },
    "repositories": [],
    "config": {
        "component-dir": "public/components",
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-apcu": "*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-intl": "*",
        "symfony/polyfill-intl-grapheme": "*",
        "symfony/polyfill-intl-icu": "*",
        "symfony/polyfill-intl-idn": "*",
        "symfony/polyfill-intl-normalizer": "*",
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-php54": "*",
        "symfony/polyfill-php56": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
            "ckeditor:install --tag=4.22.1": "symfony-cmd",
            "elfinder:install": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "ckeditor:install": "symfony-cmd"
        },
        "comment": "If CKEDITOR is installed, its auto-scripts must go BEFORE the assets:install one",
        "handle-parameters": "Incenteev\\ParameterHandler\\ScriptHandler::buildParameters",
        "post-install-cmd": [
            "@handle-parameters"
        ],
        "post-update-cmd": [
            "@handle-parameters",
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/framework-bundle": "6.2.8"
    },
    "extra": {
        "symfony": {
            "id": "01C55WKV23A7YFW4QE83HXTV7Y",
            "allow-contrib": "true",
            "require": "6.4.*"
        },
        "incenteev-parameters": [
            {
                "file": "config/parameters.yaml",
                "dist-file": "config/parameters.dist.yaml",
                "keep-outdated": true
            }
        ]
    }
}
