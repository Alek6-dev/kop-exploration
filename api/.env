# This file is a "template" of which env vars need to be defined for your application
# Copy this file to .env file for development, create environment variables when deploying to production
# https://symfony.com/doc/current/best_practices/configuration.html#infrastructure-related-configuration

SITE_NAME=kop

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
# Tu peux trouver une clé par ici : https://randomkeygen.com/#ci_key
###< symfony/framework-bundle ###

###> xdebug ###
XDEBUG_HOST=TODO
###< xdebug ###

###> docker ###
SERVER_HOST=localhost
MYSQL_DB=symfony
MYSQL_ROOT_PWD=rootpassword
MYSQL_PORT=3306
MYSQL_SERVICE=service.mysql
MYSQL_HOST=${MYSQL_SERVICE}
# Avec les environnements docker, on est obligé d'utiliser le root pour gérer les deux bases
MYSQL_USER=root
MYSQL_PWD=${MYSQL_ROOT_PWD}
MYSQL_SERVER_VERSION=8
COMPOSE_PROJECT_NAME=kop
DOCKEREXEC_ARG=
###< docker ###

###> elasticsearch ###
ELASTIC_PORT=9200
###< elasticsearch ###

###> sentry/sentry-symfony ###
SENTRY_DSN=
SENTRY_ENV=dev
###< sentry/sentry-symfony ###

###> symfony/mailer ###
# Configuration exemples :
# Built in : https://symfony.com/doc/current/mailer.html#transport-setup
# Third party : https://symfony.com/doc/current/mailer.html#using-a-3rd-party-transport
MAILER_DSN=
MAILER_SENDER_NAME=
MAILER_SENDER_EMAIL=
MAILER_SENDER_RECIPIENTS=
###< symfony/mailer ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/sendinblue-mailer ###
# MAILER_DSN=sendinblue+api://KEY@default
# MAILER_DSN=sendinblue+smtp://USERNAME:PASSWORD@default
###< symfony/sendinblue-mailer ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
# DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=c7ef1555af178d1583cc088bd26f626b960dc82a35c52a2d3c3e3b0023be256d
###< lexik/jwt-authentication-bundle ###

### URL_FRONT
URL_FRONT=https://kop.local
URL_FRONT_FORGOT_PASSWORD=${URL_FRONT}/mot-de-passe-oublie/{uuid}
URL_FRONT_VALID_REGISTRATION=${URL_FRONT}/confirmation-inscription/{uuid}

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

