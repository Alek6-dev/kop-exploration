<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            {% block title %}
                {{ "King of Paddock" }}
            {% endblock %}
        </title>
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('assets/favicon/apple-touch-icon.png') }}">
        <link rel="icon" type="image/png" sizes="32x32" media="(prefers-color-scheme: light)" href="{{ asset('assets/favicon/favicon-32x32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" media="(prefers-color-scheme: light)" href="{{ asset('assets/favicon/favicon-16x16.png') }}">
        <link rel="icon" type="image/png" sizes="32x32" media="(prefers-color-scheme: dark)" href="{{ asset('assets/favicon/favicon-white-32x32.png') }}">
        <link rel="icon" type="image/png" sizes="16x16" media="(prefers-color-scheme: dark)" href="{{ asset('assets/favicon/favicon-white-16x16.png') }}">
        <link rel="manifest" href="{{ asset('assets/favicon/site.webmanifest') }}">
        <link rel="mask-icon" href="{{ asset('assets/favicon/safari-pinned-tab.svg') }}" color="#f1c445">
        <meta name="msapplication-TileColor" content="#F1C445">
        <meta name="theme-color" content="#ffffff">
        {% block stylesheets %}{% endblock %}
        {{ encore_entry_link_tags('app') }}

        {% block javascripts %}{% endblock %}
        {{ encore_entry_script_tags('app') }}
    </head>
    <body class="{% block bodyClassName %}{% endblock %}">
        {% block header %}
            {% include 'layout/header.html.twig' %}
        {% endblock %}

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <twig:FlashMessage :type="type" message="{{ message | trans }}" />
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}

        {% block menu %}
            {% include 'layout/menu.html.twig' %}
        {% endblock %}
    </body>
</html>
