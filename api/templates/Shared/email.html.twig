{% apply inline_css(source('@public/assets/email.css')) %}
    <!DOCTYPE html PUBLIC "-//W3C//DTDXHTML1.0Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">

    <html xmlns="http://www.w3.org/1999/xhtml" lang="en" xml:lang="en">
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
        <meta name="viewport" content="width=device-width">
        <title>{{ 'title' | trans({}, 'email') }}</title>
        <style>
            a { color: #ec1d57 !important;}
        </style>
    </head>
    <body>
    <span class="preheader"></span>
    <table class="body">
        <tr>
            <td class="center" align="center" valign="top">
                <center data-parsed="">
                    <container>
                        {% block header %}
                            {% include 'Shared/includes/_header.partials.twig' %}
                        {% endblock %}

                        <row class="content">
                            <columns class="content-columns">
                                <spacer size="30"></spacer>

                                <strong style="color: #14426f;">{% block title %}{% endblock %}</strong>

                                <br><br>

                                {% block body %}{% endblock %}
                            </columns>
                        </row>
                        {% include 'Shared/includes/_footer.partials.twig' %}
                    </container>
                </center>
            </td>
        </tr>
    </table>

    <!-- prevent Gmail on iOS font size manipulation --><div style="display:none; white-space:nowrap; font:15px courier; line-height:0;">&nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;</div>
    </body>
    </html>
{% endapply %}
