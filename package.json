{
  "name": "kop-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "King of Paddock - Monorepo for API and Frontend applications",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexisKOP/kop-app"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "api:dev": "pnpm --filter @kop/api run start",
    "api:build": "pnpm --filter @kop/api run build",
    "app:dev": "pnpm --filter @kop/app run dev",
    "app:build": "pnpm --filter @kop/app run build",
    "app:lint": "pnpm --filter @kop/app run lint"
  }
}
